{
  "title": "Kublai Operations",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Readiness Status",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "kublai_readiness_status"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Pending Outbox Events",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "kublai_pending_outbox_events"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Failed Search Jobs",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "kublai_failed_search_jobs"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Incomplete GC Runs",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "kublai_incomplete_gc_runs"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Outbox Backlog",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "kublai_pending_outbox_events"
        },
        {
          "refId": "B",
          "expr": "kublai_oldest_pending_outbox_age_seconds"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Search Job Health",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "kublai_pending_search_jobs"
        },
        {
          "refId": "B",
          "expr": "kublai_failed_search_jobs"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Trust Material Status",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "expr": "kublai_oidc_trust_healthy"
        },
        {
          "refId": "B",
          "expr": "kublai_saml_trust_healthy"
        }
      ]
    }
  ]
}
